\@writefile{lof}{\contentsline {figure}{\numberline {28}{\ignorespaces Winding-class fractions $f_{\mathrm  {neg}}$ and $f_{\mathrm  {pos}}=1-f_{\mathrm  {neg}}$ per regime on the canonical-physics ladder $N\!\in \![64,512]$. Cross-regime Symanzik asymptote $f_{\mathrm  {neg},\infty }=0.28552\pm 0.00081$ matches $2/7=0.28571$ at $0.24\sigma $ (absolute deviation $2\!\times \!10^{-4}$). The closed-form derivation \textup  {\hbox {\mathsurround \z@ \normalfont  (\ignorespaces \ref  {eq:fneg-Ngen}\unskip \@@italiccorr )}} via the $B_{N_{\mathrm  {gen}}}=\mathrm  {so}(2 N_{\mathrm  {gen}}+1)$ short-root fraction is parameter-free.}}{132}{figure.28}\protected@file@percent }
\newlabel{fig:winding_class_split_57}{{28}{132}{Winding-class fractions $f_{\mathrm {neg}}$ and $f_{\mathrm {pos}}=1-f_{\mathrm {neg}}$ per regime on the canonical-physics ladder $N\!\in \![64,512]$. Cross-regime Symanzik asymptote $f_{\mathrm {neg},\infty }=0.28552\pm 0.00081$ matches $2/7=0.28571$ at $0.24\sigma $ (absolute deviation $2\!\times \!10^{-4}$). The closed-form derivation \eqref {eq:fneg-Ngen} via the $B_{N_{\mathrm {gen}}}=\mathrm {so}(2 N_{\mathrm {gen}}+1)$ short-root fraction is parameter-free}{figure.28}{}}
